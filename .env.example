# Resend (https://resend.com) — used for waitlist emails
RESEND_API_KEY=re_xxxxx
RESEND_AUDIENCE_ID=your-audience-id

# DodoPayments (https://dodopayments.com) — used for template purchases
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_ENV=test_mode
DODO_WEBHOOK_SECRET=
# Product IDs read by app/api/create-checkout/route.ts
DODO_GENERAL_SAAS_PRODUCT_ID=
DODO_LAUNCHPAD_OS_PRODUCT_ID=

# Base URL used for the Dodo checkout return_url (falls back to request origin)
NEXT_PUBLIC_SITE_URL=https://launchx.page
